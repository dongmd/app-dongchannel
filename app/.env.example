# ────────────────────────────────────────────────────────────
# DongChannel AI Operations Hub — env template
# Sao chép thành .env.local (dev) hoặc .env (production).
# TUYỆT ĐỐI KHÔNG commit file .env / .env.local.
#
# Production trên VPS vocapro: đặt tại /home/opssite/.env (chmod 600)
# sau khi CloudPanel tạo site Node.js.
# ────────────────────────────────────────────────────────────

# Next.js
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1.0

# Auth.js / NextAuth v4
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_LONG_RANDOM_STRING
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
# Tạo tại https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email allowlist (comma-separated, lowercase). Bootstrap trước khi bảng email_allowlist trong DB có dữ liệu.
# Email ĐẦU TIÊN được cấp OWNER, các email tiếp theo default VIEWER. Đổi role sau qua bảng DB.
AUTH_EMAIL_ALLOWLIST=owner@example.com

# PostgreSQL — dev local
# Prod trên VPS: postgres://opsdash:<pw>@127.0.0.1:5432/dongchannel_ops (tạo bằng `clpctl db:add`)
DATABASE_URL=postgres://ops:ops@localhost:5432/dongchannel_ops

# ────────────────────────────────────────────────────────────
# Hermes REST API (backend-only — KHÔNG bao giờ dùng NEXT_PUBLIC_ prefix)
# ────────────────────────────────────────────────────────────
# Local dev: SSH tunnel `ssh -L 9119:127.0.0.1:9119 vocapro` rồi dùng localhost.
# Prod trên VPS (systemd/nodejs site, không container): 127.0.0.1:9119 (host network).
# Nếu chạy Docker: cần `--network host` HOẶC add host.docker.internal:host-gateway.
HERMES_API_BASE_URL=http://127.0.0.1:9119

# Hermes basic auth — lấy từ /root/hermes-notes/dashboard-credentials.txt trên VPS
# ⚠️ Cùng credential dùng cho human login → nếu rotate password Hermes, phải update ở đây
HERMES_BASIC_USER=admin
HERMES_BASIC_PASSWORD=

# Hermes profiles (đã confirm qua SSH 2026-07-21)
HERMES_PROFILE_AFF=aff
HERMES_PROFILE_YT=yt

# Public URL Hermes dashboard cũ (link từ /admin của app mới — sau khi setup)
NEXT_PUBLIC_HERMES_DASHBOARD_URL=https://hermes.dongchannel.com

# Feature flags
NEXT_PUBLIC_FEATURE_NEW_OPS_DASHBOARD=true
